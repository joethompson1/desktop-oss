{
  "name": "claude-agent-sidecar",
  "version": "1.0.0",
  "type": "module",
  "description": "Thin sidecar that calls @anthropic-ai/claude-agent-sdk and relays SDKMessage events as NDJSON to stdout",
  "main": "index.mjs",
  "scripts": {
    "build": "bun build ./index.mjs --compile --outfile=./dist/claude-agent-sidecar",
    "build:darwin-arm64": "bun build ./index.mjs --compile --target=bun-darwin-arm64 --outfile=./dist/claude-agent-sidecar-darwin-arm64",
    "build:darwin-x64": "bun build ./index.mjs --compile --target=bun-darwin-x64 --outfile=./dist/claude-agent-sidecar-darwin-x64",
    "build:linux-x64": "bun build ./index.mjs --compile --target=bun-linux-x64 --outfile=./dist/claude-agent-sidecar-linux-x64",
    "build:windows-x64": "bun build ./index.mjs --compile --target=bun-windows-x64 --outfile=./dist/claude-agent-sidecar-windows-x64.exe"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.139"
  }
}
