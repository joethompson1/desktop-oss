{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" },
        { "url": "vscode://*" },
        { "url": "cursor://*" }
      ]
    },
    "store:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" }
      ]
    },
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "shell:default",
    "shell:allow-open",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "claude", "cmd": "claude", "args": true },
        { "name": "opencode", "cmd": "opencode", "args": true },
        { "name": "codex", "cmd": "codex", "args": true }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "claude", "cmd": "claude", "args": true },
        { "name": "opencode", "cmd": "opencode", "args": true },
        { "name": "codex", "cmd": "codex", "args": true }
      ]
    }
  ]
}
