{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-oss",
  "version": "0.1.0",
  "identifier": "io.github.desktop-oss",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "node sidecar/stage.mjs",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Desktop OSS",
        "width": 1200,
        "height": 800,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 20, "y": 28 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "sidecar-dist/claude-agent-bin/": "claude-agent-bin/",
      "sidecar-dist/cursor-agent-bin/": "cursor-agent-bin/"
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:desktop-oss.db"]
    }
  }
}
